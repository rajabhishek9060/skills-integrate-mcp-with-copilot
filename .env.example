# Environment Configuration Example
# Copy this file to .env and update with your settings

# Database Configuration
# For MySQL Production:
# DATABASE_URL=mysql+mysql-connector-python://username:password@localhost:3306/mergington_activities

# For SQLite Development (default):
DATABASE_URL=sqlite:///./activities.db

# MySQL Configuration (optional, for production)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=username
# MYSQL_PASSWORD=password
# MYSQL_DATABASE=mergington_activities

# Application Settings
DEBUG=False
LOG_LEVEL=INFO
